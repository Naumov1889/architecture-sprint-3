@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container_Boundary(lighting_service, "Lighting Control Service") {
    Component(lighting_api, "Lighting API", "FastAPI", "REST API для управления освещением")
    Component(lighting_controller, "Lighting Controller", "Python", "Логика управления освещением")
    Component(device_manager, "Device Manager", "Python", "Управление световыми приборами")
    Component(data_store, "Data Store", "Python", "Работа с БД")
    Component(kafka_consumer, "Kafka Consumer", "Python", "Получение событий")
}

Container(api_gateway, "API Gateway", "Python", "Входная точка API")
Container(database, "Lighting DB", "PostgreSQL", "База данных освещения")
Container(kafka, "Kafka", "Apache Kafka", "Шина событий")
Container(devices, "IoT устройства", "Lamps, Switches", "Световые приборы")

Rel(api_gateway, lighting_api, "HTTP/REST")
Rel(lighting_api, lighting_controller, "Использует")
Rel(lighting_controller, device_manager, "Управляет")
Rel(lighting_controller, data_store, "Использует")
Rel(data_store, database, "SQL")
Rel(kafka, kafka_consumer, "События")
Rel(kafka_consumer, lighting_controller, "Обрабатывает события")
Rel(device_manager, devices, "Управляет")
Rel(devices, kafka, "Отправляет события")
@enduml