@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container_Boundary(gate_service, "Gate Control Service") {
    Component(gate_api, "Gate API", "FastAPI", "REST API для управления воротами")
    Component(gate_controller, "Gate Controller", "Python", "Логика управления воротами")
    Component(device_manager, "Device Manager", "Python", "Управление воротами и приводами")
    Component(data_store, "Data Store", "Python", "Работа с БД")
    Component(kafka_consumer, "Kafka Consumer", "Python", "Получение событий")
}

Container(api_gateway, "API Gateway", "Python", "Входная точка API")
Container(database, "Gate DB", "PostgreSQL", "База данных ворот")
Container(kafka, "Kafka", "Apache Kafka", "Шина событий")
Container(devices, "IoT устройства", "Gates, Motors", "Устройства ворот")

Rel(api_gateway, gate_api, "HTTP/REST")
Rel(gate_api, gate_controller, "Использует")
Rel(gate_controller, device_manager, "Управляет")
Rel(gate_controller, data_store, "Использует")
Rel(data_store, database, "SQL")
Rel(kafka, kafka_consumer, "События")
Rel(kafka_consumer, gate_controller, "Обрабатывает события")
Rel(device_manager, devices, "Управляет")
Rel(devices, kafka, "Отправляет события")
@enduml